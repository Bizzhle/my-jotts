{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "globalSetup": "<rootDir>/test/test-helper/globalSetup.ts",
  "setupFilesAfterEnv": ["<rootDir>/test/test-helper/setupTest.ts"],
  "testEnvironment": "node",
  "testRegex": "test/.*\\.e2e-spec\\.ts$",
  "moduleNameMapper": {
    "^@thallesp/nestjs-better-auth$": "<rootDir>/test/test-helper/mocks/nestjs-better-auth.mock.ts",
    "^src/(.*)$": "<rootDir>/src/$1"
  },
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  }
}
